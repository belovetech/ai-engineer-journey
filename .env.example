# Required: at least one provider key
OPENAI_API_KEY=sk-...

# Optional: Gemini provider support
# GEMINI_API_KEY=AI...

# Optional: switch the active LLM provider (openai | gemini)
# LLM_PROVIDER=openai

# Optional: override default model names
# CHAT_MODEL=gpt-4.1
# GEMINI_MODEL=gemini-3.1-flash-lite
# EMBED_MODEL=text-embedding-3-small
